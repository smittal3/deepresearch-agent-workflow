# Copy this file to ".env" and paste your keys in.
# (You can also paste them into the app's sidebar instead of using this file.)

# Required — powers all four agents. Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional — powers the Web Researcher agent (Tavily search). Free tier at:
# https://app.tavily.com  (without it, the web-search agent is skipped)
TAVILY_API_KEY=your_tavily_api_key_here
